{
  "manifest_version": 3,
  "name": "EAL — Cognitive Shield · الدرع المعرفي",
  "version": "0.1.0",
  "description": "Check any claim against the Egyptian Awareness Library's One-Law verification — real cited sources, or it says UNVERIFIED. Defense at the point of exposure.",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://*.x.com/*",
    "https://*.twitter.com/*",
    "https://*.youtube.com/*",
    "https://web.whatsapp.com/*",
    "http://localhost/*"
  ],
  "action": { "default_popup": "popup.html", "default_title": "EAL — check a claim" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*",
        "https://*.x.com/*",
        "https://*.twitter.com/*",
        "https://*.youtube.com/*",
        "https://web.whatsapp.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
