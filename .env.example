# ============================================================
# Egyptian Awareness Library — Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# --- Chunk 1: Fact-Check APIs ---
# Google Fact Check Tools API (free, requires API key from Google Cloud Console)
# https://developers.google.com/fact-check/tools/api
GOOGLE_FACTCHECK_API_KEY=

# ClaimBuster API (free, get key from https://idir.uta.edu/claimbuster/)
CLAIMBUSTER_API_KEY=

# --- Chunk 1.3: Veracity RAG Pipeline ---
# Self-hosted Veracity backend URL (e.g. http://your-veracity-server:5000)
VERACITY_BACKEND_URL=
VERACITY_BACKEND_TOKEN=

# --- Chunk 4: Islamic Text APIs ---
# Sunnah.com Hadith API (free key from https://sunnah.com/developers)
HADITH_API_KEY=
SUNNAH_API_KEY=
SUNNAH_HADITH_SEARCH_URL=
# HadithAPI.com — searchable, GRADED hadith (free key from https://hadithapi.com).
# Activates real isnād-graded retrieval in the debunking swarm (EAL Standard §4.2).
# Without it, the engine honestly abstains on hadith grading instead of guessing.
HADITHAPI_COM_KEY=

# Kalimat Semantic Search (https://api.kalimat.dev/)
KALIMAT_API_URL=
KALIMAT_API_KEY=

# --- Chunk 5: AI Chat Providers (cascading fallback: Gemini → Groq → GitHub → HuggingFace) ---
# At least ONE key is required for /chatbot to function.
# All are optional individually; the system tries each provider in order.
GEMINI_API_KEY=
GROQ_API_KEY=
GITHUB_TOKEN=
HF_TOKEN=

# --- Chunk 6: Reverse Image Search ---
# SerpApi Google Lens (get key from https://serpapi.com/)
SERPAPI_API_KEY=

# --- Chunk 9: TinEye Reverse Image Search ---
# ⚠️  NOT IMPLEMENTED in current source code. Kept for future reference only.
# These variables are NOT read by any route or component.
# TINEYE_API_URL=https://api.tineye.com/rest
# TINEYE_API_USERNAME=
# TINEYE_API_KEY=

# --- Forensics Python Backend (ExifTool + c2patool + CAMeL Tools) ---
# Point this at the FastAPI backend base URL
# Docker Compose sets this automatically; for local dev use localhost
FORENSIC_BACKEND_URL=http://localhost:8000
FORENSIC_BACKEND_TOKEN=

# --- Arabic NLP Backend (CAMeL Tools) ---
# Point this at the /arabic endpoint on the FastAPI backend
ARABIC_NLP_BACKEND_URL=http://localhost:8000/arabic
ARABIC_NLP_BACKEND_TOKEN=

# --- Pilot Admin Access ---
# Admin code for supervisor dashboard access (pilot-phase only)
NEXT_PUBLIC_ADMIN_CODE=

# --- Authentication ---
# JWT secret for signing auth tokens (generate a strong random string)
JWT_SECRET=
# Admin registration code (required to register as admin)
ADMIN_REGISTRATION_CODE=

# --- NVIDIA NIM API (PRIMARY AI Provider) ---
# Get your API key from https://build.nvidia.com → Get API Key
# Supports up to 5 keys for high-throughput rotation
# Powers: MegaRotator primary model, Content Safety, Deepfake Detection
NVIDIA_API_KEY=
NVIDIA_API_KEY_2=
NVIDIA_API_KEY_3=
NVIDIA_API_KEY_4=
NVIDIA_API_KEY_5=
